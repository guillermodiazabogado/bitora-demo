# BITORA - ejemplo de variables para despliegue
# Copiar como .env solo en entornos locales. En Render/Railway se cargan desde el panel.

APP_ENV=demo
BASE_URL=https://bitora-demo.onrender.com
HTTPS_REQUIRED=true

# Render/Railway asignan PORT automaticamente. En local se puede usar QR_PORT=8787.
PORT=10000
QR_HOST=0.0.0.0

# Base demo/local. PostgreSQL queda preparado para una fase posterior.
QR_DB_ENGINE=sqlite
QR_SQLITE_PATH=acreditaciones.sqlite3
QR_POSTGRES_DSN=

# Seguridad operativa
QR_REQUIRE_LOGIN=1

# Backups locales de SQLite
QR_AUTO_BACKUP_MINUTES=10
QR_BACKUP_KEEP_LAST=24
