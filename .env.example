# BITORA - ejemplo de variables para despliegue
# Copiar como .env solo en entornos locales. En Render/Railway se cargan desde el panel.

APP_ENV=demo
BASE_URL=https://bitora-demo.onrender.com
HTTPS_REQUIRED=true

# Render/Railway asignan PORT automaticamente. En local se puede usar QR_PORT=8787.
PORT=10000
QR_HOST=0.0.0.0

# Base de datos. SQLite para local/demo; PostgreSQL para online seria/produccion.
QR_DB_ENGINE=sqlite
QR_SQLITE_PATH=acreditaciones.sqlite3
QR_POSTGRES_DSN=
QR_POSTGRES_POOL_MIN=1
QR_POSTGRES_POOL_MAX=10

# Seguridad operativa
QR_REQUIRE_LOGIN=1

# Backups locales de SQLite
QR_AUTO_BACKUP_MINUTES=10
QR_BACKUP_KEEP_LAST=24

# Email real. Mantener EMAIL_ENABLED=false hasta verificar dominio y remitente.
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=BITORA <eventos@tu-dominio.com>
EMAIL_REPLY_TO=
EMAIL_ENABLED=false
EMAIL_MAX_RETRIES=3
EMAIL_WEBHOOK_SECRET=
